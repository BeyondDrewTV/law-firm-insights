{
  "agents": {
    "chief_of_staff": {
      "model": "anthropic/claude-3-5-sonnet",
      "max_output_tokens": 1000,
      "temperature": 0.2,
      "cadence": "weekly"
    },
    "customer_discovery": {
      "model": "anthropic/claude-3-haiku",
      "max_output_tokens": 1800,
      "temperature": 0.3,
      "cadence": "weekly",
      "token_budget_warning_multiplier": 1.2
    },
    "default": {
      "model": "anthropic/claude-3-haiku",
      "max_output_tokens": 600,
      "temperature": 0.3,
      "cadence": "weekly"
    }
  },
  "reports": {
    "retention_days": 90,
    "output_dir": "reports"
  },
  "cost_control": {
    "max_input_tokens_department": 1500,
    "max_input_tokens_chief_of_staff": 4000,
    "warn_on_budget_exceed_pct": 20
  }
}
